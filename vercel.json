{
  "version": 2,
  "builds": [
    {
      "src": "app_torch.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "app_torch.py"
    }
  ],
  "env": {
    "PYTHONPATH": "."
  }
}
